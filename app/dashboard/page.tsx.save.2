'use client'

import { useEffect, useMemo, useState } from 'react'
import { useRouter } from 'next/navigation'
import { createClient } from '@/utils/supabase/client'

type Property = {
  id: string
  name: string
  address: string | null
  city: string | null
  state: string | null
  created_at: string
}

type Project = {
  id: string
  name: string
  description: string | null
  property_id: string
  created_at: string
}

type TabKey =
  | 'overview'
  | 'properties'
  | 'projects'
  | 'history'
  | 'reports'
  | 'files'

export default function DashboardPage() {
  const router = useRouter()
  const supabase = createClient()

  const [userId, setUserId] = useState<string | null>(null)
  const [userEmail, setUserEmail] = useState<string | null>(null)
  const [loading, setLoading] = useState(true)

  const [activeTab, setActiveTab] = useState<TabKey>('overview')

  const [properties, setProperties] = useState<Property[]>([])
  const [projects, setProjects] = useState<Project[]>([])
  const [selectedPropertyId, setSelectedPropertyId] = useState<string | null>(null)

  const [name, setName] = useState('')
  const [address, setAddress] = useState('')
  const [city, setCity] = useState('')
  const [stateName, setStateName] = useState('')
  const [creatingProperty, setCreatingProperty] = useState(false)

  const [projectPropertyId, setProjectPropertyId] = useState('')
  const [projectName, setProjectName] = useState('')
  const [projectDescription, setProjectDescription] = useState('')
  const [creatingProject, setCreatingProject] = useState(false)

  const [historyNote, setHistoryNote] = useState('')
  const [historyItems, setHistoryItems] = useState<string[]>([
    'Initial property intelligence dashboard created.',
    'Track recurring issues, inspections, and storm-related observations here.',
  ])

  useEffect(() => {
    const loadDashboard = async () => {
      const {
        data: { user },
        error: userError,
      } = await supabase.auth.getUser()

      if (userError || !user) {
        router.replace('/login')
        return
      }

      setUserId(user.id)
      setUserEmail(user.email ?? null)

      const { data: propertyData, error: propertyError } = await supabase
        .from('properties')
        .select('*')
        .eq('user_id', user.id)
        .order('created_at', { ascending: false })

      const { data: projectData, error: projectError } = await supabase
        .from('projects')
        .select('*')
        .eq('user_id', user.id)
        .order('created_at', { ascending: false })

      if (propertyError) {
        console.error('Error loading properties:', propertyError.message)
      }

      if (projectError) {
        console.error('Error loading projects:', projectError.message)
      }

      const nextProperties = (propertyData ?? []) as Property[]
      const nextProjects = (projectData ?? []) as Project[]

      setProperties(nextProperties)
      setProjects(nextProjects)

      const firstPropertyId = nextProperties[0]?.id ?? null
      setSelectedPropertyId(firstPropertyId)
      setProjectPropertyId(firstPropertyId ?? '')

      setLoading(false)
    }

    loadDashboard()
  }, [router, supabase])

  const selectedProperty = useMemo(() => {
    return properties.find((property) => property.id === selectedPropertyId) ?? null
  }, [properties, selectedPropertyId])

  const selectedPropertyProjects = useMemo(() => {
    if (!selectedProperty) return []
    return projects.filter((project) => project.property_id === selectedProperty.id)
  }, [projects, selectedProperty])

  const urgentAlerts = useMemo(() => {
    if (!selectedProperty) return []

    return [
      'Review drainage paths and standing water risk',
      'Check roof edge, gutters, and downspout discharge',
      'Inspect crawlspace or foundation moisture signs',
      'Verify HVAC service date and filter cycle',
    ]
  }, [selectedProperty])

  const handleCreateProperty = async (e: React.FormEvent) => {
    e.preventDefault()

    if (!userId) return
    setCreatingProperty(true)

    const { data, error } = await supabase
      .from('properties')
      .insert({
        user_id: userId,
        name,
        address,
        city,
        state: stateName,
      })
      .select()
      .single()

    setCreatingProperty(false)

    if (error) {
      alert(error.message)
      return
    }

    const newProperty = data as Property
    setProperties((prev) => [newProperty, ...prev])
    setSelectedPropertyId(newProperty.id)
    setProjectPropertyId(newProperty.id)

    setName('')
    setAddress('')
    setCity('')
    setStateName('')
  }

  const handleCreateProject = async (e: React.FormEvent) => {
    e.preventDefault()

    if (!userId || !projectPropertyId) return
    setCreatingProject(true)

    const { data, error } = await supabase
      .from('projects')
      .insert({
        user_id: userId,
        property_id: projectPropertyId,
        name: projectName,
        description: projectDescription,
      })
      .select()
      .single()

    setCreatingProject(false)

    if (error) {
      alert(error.message)
      return
    }

    const newProject = data as Project
    setProjects((prev) => [newProject, ...prev])
    setProjectName('')
    setProjectDescription('')
  }

  const handleAddHistory = (e: React.FormEvent) => {
    e.preventDefault()

    if (!historyNote.trim()) return

    setHistoryItems((prev) => [historyNote.trim(), ...prev])
    setHistoryNote('')
  }

  const handleReportAction = (action: 'download' | 'share' | 'copy') => {
    if (!selectedProperty) {
      alert('Select a property first.')
      return
    }

    if (action === 'download') {
      alert(`Download report placeholder for ${selectedProperty.name}`)
    }

    if (action === 'share') {
      alert(`Share report placeholder for ${selectedProperty.name}`)
    }

    if (action === 'copy') {
      const summary = [
        `Property Report: ${selectedProperty.name}`,
        `Address: ${[selectedProperty.address, selectedProperty.city, selectedProperty.state]
          .filter(Boolean)
          .join(', ')}`,
        `Active projects: ${selectedPropertyProjects.length}`,
        `Urgent watch items: ${urgentAlerts.length}`,
      ].join('\n')

      navigator.clipboard.writeText(summary)
      alert('Report summary copied.')
    }
  }

  const tabs: { key: TabKey; label: string }[] = [
    { key: 'overview', label: 'Overview' },
    { key: 'properties', label: 'Properties' },
    { key: 'projects', label: 'Projects' },
    { key: 'history', label: 'History' },
    { key: 'reports', label: 'Reports' },
    { key: 'files', label: 'Files' },
  ]

  if (loading) {
    return (
      <main className="min-h-screen bg-black text-white flex items-center justify-center">
        <p className="text-sm text-gray-400">Loading property intelligence workspace...</p>
      </main>
    )
  }

  return (
    <main className="min-h-screen bg-black text-white px-6 py-8 space-y-8 max-w-7xl mx-auto">
      <header className="space-y-4 border-b border-gray-800 pb-4">
        <div className="flex items-baseline justify-between gap-4">
          <div>
            <h1 className="text-4xl font-bold tracking-tight">Property Intelligence Dashboard</h1>
            <p className="text-sm text-gray-400">
              Signed in as{' '}
              <span className="font-medium text-gray-200">
                {userEmail ?? 'Unknown user'}
              </span>
            </p>
          </div>
        </div>

        <nav className="flex flex-wrap gap-2">
          {tabs.map((tab) => {
            const isActive = activeTab === tab.key

            return (
              <button
                key={tab.key}
                type="button"
                onClick={() => setActiveTab(tab.key)}
                className={`rounded-full border px-4 py-2 text-sm transition ${
                  isActive
                    ? 'border-emerald-500 bg-emerald-950/40 text-emerald-200'
                    : 'border-gray-700 bg-zinc-950 text-gray-300 hover:border-gray-500'
                }`}
              >
                {tab.label}
              </button>
            )
          })}
        </nav>
      </header>

      <section className="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div className="rounded-xl border border-gray-800 bg-zinc-950 p-4">
          <p className="text-xs uppercase tracking-wide text-gray-400">Total Properties</p>
          <p className="mt-2 text-3xl font-semibold">{properties.length}</p>
          <p className="mt-2 text-sm text-gray-500">Tracked land and dwelling records</p>
        </div>

        <div className="rounded-xl border border-gray-800 bg-zinc-950 p-4">
          <p className="text-xs uppercase tracking-wide text-gray-400">Total Projects</p>
          <p className="mt-2 text-3xl font-semibold">{projects.length}</p>
          <p className="mt-2 text-sm text-gray-500">Maintenance and improvement work items</p>
        </div>

        <div className="rounded-xl border border-gray-800 bg-zinc-950 p-4">
          <p className="text-xs uppercase tracking-wide text-gray-400">Urgent Watch Items</p>
          <p className="mt-2 text-3xl font-semibold">{urgentAlerts.length}</p>
          <p className="mt-2 text-sm text-gray-500">Preventive checks needing attention</p>
        </div>

        <div className="rounded-xl border border-gray-800 bg-zinc-950 p-4">
          <p className="text-xs uppercase tracking-wide text-gray-400">Selected Property</p>
          <p className="mt-2 text-lg font-semibold">
            {selectedProperty ? selectedProperty.name : 'None selected'}
          </p>
          <p className="mt-2 text-sm text-gray-500">
            {selectedProperty
              ? [selectedProperty.address, selectedProperty.city, selectedProperty.state]
                  .filter(Boolean)
                  .join(', ')
              : 'Select a property from the Properties tab'}
          </p>
        </div>
      </section>

      {activeTab === 'overview' && (
        <section className="grid gap-6 lg:grid-cols-[1.3fr_0.9fr]">
          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-5">
            <div>
              <h2 className="text-2xl font-semibold">Overview</h2>
              <p className="text-sm text-gray-400">
                High-level awareness, diagnostics, and operational focus.
              </p>
            </div>

            {selectedProperty ? (
              <div className="grid gap-4 md:grid-cols-2">
                <div className="rounded-lg border border-gray-800 bg-black p-4">
                  <p className="text-xs uppercase tracking-wide text-gray-500">Identity</p>
                  <h3 className="mt-2 text-lg font-semibold">{selectedProperty.name}</h3>
                  <p className="mt-2 text-sm text-gray-400">
                    {selectedProperty.address ?? 'No address entered'}
                  </p>
                  <p className="text-sm text-gray-400">
                    {[selectedProperty.city, selectedProperty.state].filter(Boolean).join(', ') ||
                      'City/state missing'}
                  </p>
                </div>

                <div className="rounded-lg border border-gray-800 bg-black p-4">
                  <p className="text-xs uppercase tracking-wide text-gray-500">Project Activity</p>
                  <p className="mt-2 text-3xl font-semibold">{selectedPropertyProjects.length}</p>
                  <p className="mt-2 text-sm text-gray-400">
                    Projects linked to this property
                  </p>
                </div>

                <div className="rounded-lg border border-gray-800 bg-black p-4 md:col-span-2">
                  <p className="text-xs uppercase tracking-wide text-gray-500">
                    Critical Oversight Areas
                  </p>
                  <div className="mt-3 grid gap-3 sm:grid-cols-2">
                    <div className="rounded-md border border-gray-800 p-3">
                      <p className="font-medium">Drainage & water movement</p>
                      <p className="text-sm text-gray-400">
                        Pooling, erosion, gutter discharge, grading near foundation.
                      </p>
                    </div>
                    <div className="rounded-md border border-gray-800 p-3">
                      <p className="font-medium">Roof, envelope & moisture</p>
                      <p className="text-sm text-gray-400">
                        Shingles, flashing, soffits, siding, stains, intrusion signals.
                      </p>
                    </div>
                    <div className="rounded-md border border-gray-800 p-3">
                      <p className="font-medium">Mechanical & utilities</p>
                      <p className="text-sm text-gray-400">
                        HVAC, plumbing leaks, electrical notes, water heater age.
                      </p>
                    </div>
                    <div className="rounded-md border border-gray-800 p-3">
                      <p className="font-medium">Grounds & adaptive changes</p>
                      <p className="text-sm text-gray-400">
                        Trees, roots, overgrowth, irrigation, hardscape movement.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <div className="rounded-lg border border-gray-800 bg-black p-4 text-sm text-gray-400">
                No property selected yet.
              </div>
            )}
          </div>

          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-5">
            <div>
              <h2 className="text-2xl font-semibold">Watchlist</h2>
              <p className="text-sm text-gray-400">
                Preventive attention areas and operational reminders.
              </p>
            </div>

            {urgentAlerts.length > 0 ? (
              <div className="space-y-3">
                {urgentAlerts.map((alert) => (
                  <div
                    key={alert}
                    className="rounded-lg border border-amber-700/40 bg-amber-950/20 p-4"
                  >
                    <p className="text-sm font-medium text-amber-200">{alert}</p>
                  </div>
                ))}
              </div>
            ) : (
              <div className="rounded-lg border border-gray-800 bg-black p-4 text-sm text-gray-400">
                No active watch items yet.
              </div>
            )}
          </div>
        </section>
      )}

      {activeTab === 'properties' && (
        <section className="grid gap-6 lg:grid-cols-[1fr_1fr]">
          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-4">
            <div>
              <h2 className="text-2xl font-semibold">Properties</h2>
              <p className="text-sm text-gray-400">
                Create, view, and directly select a property without leaving the workspace.
              </p>
            </div>

            <form onSubmit={handleCreateProperty} className="grid gap-3 max-w-xl">
              <input
                value={name}
                onChange={(e) => setName(e.target.value)}
                placeholder="Property name"
                className="border rounded px-3 py-2 bg-black"
                required
              />
              <input
                value={address}
                onChange={(e) => setAddress(e.target.value)}
                placeholder="Address"
                className="border rounded px-3 py-2 bg-black"
              />
              <input
                value={city}
                onChange={(e) => setCity(e.target.value)}
                placeholder="City"
                className="border rounded px-3 py-2 bg-black"
              />
              <input
                value={stateName}
                onChange={(e) => setStateName(e.target.value)}
                placeholder="State"
                className="border rounded px-3 py-2 bg-black"
              />
              <button
                type="submit"
                disabled={creatingProperty}
                className="bg-black text-white rounded px-4 py-2 border border-gray-700"
              >
                {creatingProperty ? 'Creating...' : 'Create Property'}
              </button>
            </form>
          </div>

          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-4">
            <div>
              <h2 className="text-2xl font-semibold">Property List</h2>
              <p className="text-sm text-gray-400">
                Click any property to focus the rest of the workspace on it.
              </p>
            </div>

            <div className="grid gap-3">
              {properties.length === 0 ? (
                <div className="rounded-lg border border-gray-800 bg-black p-4 text-sm text-gray-400">
                  No properties yet.
                </div>
              ) : (
                properties.map((property) => {
                  const isSelected = property.id === selectedPropertyId

                  return (
                    <button
                      key={property.id}
                      type="button"
                      onClick={() => {
                        setSelectedPropertyId(property.id)
                        setProjectPropertyId(property.id)
                      }}
                      className={`flex flex-col items-start rounded border p-4 text-left transition ${
                        isSelected
                          ? 'border-emerald-500 bg-emerald-950/30'
                          : 'border-gray-700 bg-black hover:border-gray-500'
                      }`}
                    >
                      <h3 className="font-semibold">{property.name}</h3>
                      <p className="text-sm text-gray-400">
                        {[property.address, property.city, property.state]
                          .filter(Boolean)
                          .join(', ')}
                      </p>
                      {isSelected && (
                        <p className="mt-1 text-xs uppercase tracking-wide text-emerald-300">
                          Focused across tabs
                        </p>
                      )}
                    </button>
                  )
                })
              )}
            </div>
          </div>
        </section>
      )}

      {activeTab === 'projects' && (
        <section className="grid gap-6 lg:grid-cols-[1fr_1fr]">
          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-4">
            <div>
              <h2 className="text-2xl font-semibold">Projects</h2>
              <p className="text-sm text-gray-400">
                Create stand-alone work items or property-specific tasks.
              </p>
            </div>

            {properties.length === 0 ? (
              <div className="rounded-lg border border-gray-800 bg-black p-4 text-sm text-gray-400">
                Add a property first before creating a project.
              </div>
            ) : (
              <form
                onSubmit={handleCreateProject}
                className="grid gap-3 max-w-xl rounded-lg border border-gray-800 bg-black p-4"
              >
                <select
                  value={projectPropertyId}
                  onChange={(e) => setProjectPropertyId(e.target.value)}
                  className="border rounded px-3 py-2 bg-black"
                  required
                >
                  <option value="">Select property</option>
                  {properties.map((property) => (
                    <option key={property.id} value={property.id}>
                      {property.name}
                    </option>
                  ))}
                </select>

                <input
                  value={projectName}
                  onChange={(e) => setProjectName(e.target.value)}
                  placeholder="Project name"
                  className="border rounded px-3 py-2 bg-black"
                  required
                />

                <textarea
                  value={projectDescription}
                  onChange={(e) => setProjectDescription(e.target.value)}
                  placeholder="Description"
                  className="border rounded px-3 py-2 bg-black"
                  rows={4}
                />

                <button
                  type="submit"
                  disabled={creatingProject || !projectPropertyId}
                  className="bg-black text-white rounded px-4 py-2 border border-gray-700 disabled:opacity-50"
                >
                  {creatingProject ? 'Creating...' : 'Create Project'}
                </button>
              </form>
            )}
          </div>

          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-4">
            <div>
              <h2 className="text-2xl font-semibold">Project List</h2>
              <p className="text-sm text-gray-400">
                Viewing {selectedProperty ? `projects for ${selectedProperty.name}` : 'all projects'}.
              </p>
            </div>

            <div className="grid gap-3">
              {(selectedProperty ? selectedPropertyProjects : projects).length === 0 ? (
                <div className="rounded-lg border border-gray-800 bg-black p-4 text-sm text-gray-400">
                  No projects to show.
                </div>
              ) : (
                (selectedProperty ? selectedPropertyProjects : projects).map((project) => (
                  <div
                    key={project.id}
                    className="rounded-lg border border-gray-800 bg-black p-4"
                  >
                    <h3 className="font-semibold">{project.name}</h3>
                    <p className="text-sm text-gray-400">
                      {project.description || 'No description provided.'}
                    </p>
                  </div>
                ))
              )}
            </div>
          </div>
        </section>
      )}

      {activeTab === 'history' && (
        <section className="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-4">
            <div>
              <h2 className="text-2xl font-semibold">History & Notes</h2>
              <p className="text-sm text-gray-400">
                Log stand-alone observations, changes, recurring issues, and oversight notes.
              </p>
            </div>

            <form onSubmit={handleAddHistory} className="grid gap-3">
              <textarea
                value={historyNote}
                onChange={(e) => setHistoryNote(e.target.value)}
                placeholder="Add an observation, inspection note, or issue history entry..."
                className="border rounded px-3 py-2 bg-black"
                rows={5}
              />
              <button
                type="submit"
                className="bg-black text-white rounded px-4 py-2 border border-gray-700"
              >
                Add History Note
              </button>
            </form>
          </div>

          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-4">
            <div>
              <h2 className="text-2xl font-semibold">Timeline</h2>
              <p className="text-sm text-gray-400">
                Working log for the selected property or general property intelligence notes.
              </p>
            </div>

            <div className="space-y-3">
              {historyItems.map((item, index) => (
                <div key={`${item}-${index}`} className="rounded-lg border border-gray-800 bg-black p-4">
                  <p className="text-sm text-gray-300">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {activeTab === 'reports' && (
        <section className="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-5">
            <div>
              <h2 className="text-2xl font-semibold">Report Preview</h2>
              <p className="text-sm text-gray-400">
                A high-level property summary for viewing, download, and sharing.
              </p>
            </div>

            <div className="rounded-lg border border-gray-800 bg-black p-5 space-y-4">
              <div>
                <p className="text-xs uppercase tracking-wide text-gray-500">Property report</p>
                <h3 className="mt-2 text-2xl font-semibold">
                  {selectedProperty ? selectedProperty.name : 'No property selected'}
                </h3>
                <p className="mt-1 text-sm text-gray-400">
                  {selectedProperty
                    ? [selectedProperty.address, selectedProperty.city, selectedProperty.state]
                        .filter(Boolean)
                        .join(', ')
                    : 'Choose a property from the Properties tab'}
                </p>
              </div>

              <div className="grid gap-3 sm:grid-cols-3">
                <div className="rounded-md border border-gray-800 p-3">
                  <p className="text-xs uppercase tracking-wide text-gray-500">Projects</p>
                  <p className="mt-2 text-xl font-semibold">{selectedPropertyProjects.length}</p>
                </div>
                <div className="rounded-md border border-gray-800 p-3">
                  <p className="text-xs uppercase tracking-wide text-gray-500">Watch items</p>
                  <p className="mt-2 text-xl font-semibold">{urgentAlerts.length}</p>
                </div>
                <div className="rounded-md border border-gray-800 p-3">
                  <p className="text-xs uppercase tracking-wide text-gray-500">History notes</p>
                  <p className="mt-2 text-xl font-semibold">{historyItems.length}</p>
                </div>
              </div>

              <div className="rounded-md border border-gray-800 p-4">
                <p className="font-medium">Report summary</p>
                <p className="mt-2 text-sm text-gray-400">
                  This property overview combines identity, current projects, watch items,
                  maintenance attention areas, and logged notes into one accessible summary.
                </p>
              </div>
            </div>
          </div>

          <div className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-4">
            <div>
              <h2 className="text-2xl font-semibold">Report Actions</h2>
              <p className="text-sm text-gray-400">
                View, copy, download, and share flows start here.
              </p>
            </div>

            <button
              type="button"
              onClick={() => handleReportAction('download')}
              className="w-full rounded-lg border border-gray-700 bg-black px-4 py-3 text-left hover:border-gray-500"
            >
              Download PDF
            </button>

            <button
              type="button"
              onClick={() => handleReportAction('share')}
              className="w-full rounded-lg border border-gray-700 bg-black px-4 py-3 text-left hover:border-gray-500"
            >
              Share Report
            </button>

            <button
              type="button"
              onClick={() => handleReportAction('copy')}
              className="w-full rounded-lg border border-gray-700 bg-black px-4 py-3 text-left hover:border-gray-500"
            >
              Copy Summary
            </button>

            <div className="rounded-lg border border-dashed border-gray-700 bg-black p-4 text-sm text-gray-400">
              Next step: connect this panel to real PDF export, public share links, and saved report history.
            </div>
          </div>
        </section>
      )}

      {activeTab === 'files' && (
        <section className="rounded-xl border border-gray-800 bg-zinc-950 p-5 space-y-4">
          <div>
            <h2 className="text-2xl font-semibold">Files & Evidence</h2>
            <p className="text-sm text-gray-400">
              This area should hold photos, receipts, PDFs, maps, and before/after evidence.
            </p>
          </div>

          <div className="grid gap-4 md:grid-cols-3">
            <div className="rounded-lg border border-gray-800 bg-black p-4">
              <p className="font-medium">Inspection photos</p>
              <p className="mt-2 text-sm text-gray-400">
                Upload roof, drainage, crawlspace, tree, and damage images here.
              </p>
            </div>
            <div className="rounded-lg border border-gray-800 bg-black p-4">
              <p className="font-medium">Documents</p>
              <p className="mt-2 text-sm text-gray-400">
                Store invoices, receipts, reports, permits, and vendor files.
              </p>
            </div>
            <div className="rounded-lg border border-gray-800 bg-black p-4">
              <p className="font-medium">Mapped evidence</p>
              <p className="mt-2 text-sm text-gray-400">
                Keep site maps, sketches, drainage notes, and marked-up visuals accessible.
              </p>
            </div>
          </div>
        </section>
      )}
    </main>
  
 )
}
